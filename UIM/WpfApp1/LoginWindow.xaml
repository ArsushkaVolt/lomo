<Window x:Class="WpfApp1.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="320" Width="420" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Background="#F5F5F5" Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="ПО УИМ" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Логин" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="txtLogin" Text="operator" Height="32" Margin="0,0,0,12"/>

            <TextBlock Text="Пароль" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <PasswordBox x:Name="txtPassword" Height="32" Margin="0,0,0,20"/>

            <Button Content="Войти" Height="42" Background="#007ACC" Foreground="White" FontSize="14" 
                    Click="BtnLogin_Click"/>
        </StackPanel>
    </Grid>
</Window>