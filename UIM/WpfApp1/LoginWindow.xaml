<Window x:Class="UIM.UI.WPF.Views.LoginWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в ПО УИМ" Height="300" Width="400">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Логин" Margin="0,0,0,5"/>
            <TextBox x:Name="txtLogin"/>

            <TextBlock Text="Пароль" Margin="0,10,0,5"/>
            <PasswordBox x:Name="txtPassword"/>

            <Button Content="Войти" Click="Login_Click" Margin="0,20,0,0" Height="35"/>
        </StackPanel>
    </Grid>
</Window>