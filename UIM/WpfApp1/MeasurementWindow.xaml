<Window x:Class="WpfApp1.MeasurementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Измерение элемента" Height="450" Width="800">
    
    
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и тип элемента -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Тип элемента:" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <ComboBox x:Name="cmbElementType" Width="180" Margin="12,0" FontSize="14" SelectedIndex="2">
                <ComboBoxItem>Точка</ComboBoxItem>
                <ComboBoxItem>Прямая</ComboBoxItem>
                <ComboBoxItem>Окружность</ComboBoxItem>
                <ComboBoxItem>Эллипс</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <!-- Режим измерения -->
        <GroupBox Grid.Row="1" Header="Режим измерения" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="12">
                <RadioButton x:Name="rbSingle" Content="Одиночное измерение" IsChecked="True" Margin="0,0,20,0"/>
                <RadioButton x:Name="rbMultiple" Content="Многократное измерение (серия)" Margin="0,0,20,0"/>
                <TextBlock Text="Количество в серии:" Margin="20,0,8,0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtSeriesCount" Text="5" Width="60" Height="26" TextAlignment="Center"/>
            </StackPanel>
        </GroupBox>

        <!-- Основная область -->
        <GroupBox Grid.Row="2" Header="Результаты измерения" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- Информация -->
                <StackPanel Grid.Column="0" Margin="12">
                    <TextBlock Text="Текущие координаты:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="txtCurrentX" Text="X = 0,0000" FontSize="15" Margin="4"/>
                    <TextBlock x:Name="txtCurrentY" Text="Y = 0,0000" FontSize="15" Margin="4"/>

                    <Separator Margin="0,20"/>

                    <TextBlock Text="Статистика серии:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="txtAverage" Text="Среднее: —" Margin="4"/>
                    <TextBlock x:Name="txtSKO" Text="СКО: —" Margin="4" Foreground="#0066CC"/>
                    <TextBlock x:Name="txtPointsCount" Text="Точек в элементе: 0" Margin="4"/>
                </StackPanel>

                <!-- Список точек -->
                <ListBox x:Name="lstPoints" Grid.Column="1" Margin="8" Background="White"/>
            </Grid>
        </GroupBox>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Фиксировать точку" Width="160" Height="42" FontSize="14" 
                    Background="#007ACC" Foreground="White" Click="BtnFixPoint_Click"/>

            <Button Content="Отмена последней" Width="140" Height="42" Margin="12,0" Click="BtnCancelLast_Click"/>

            <Button Content="Завершить элемент" Width="160" Height="42" 
                    Background="#28A745" Foreground="White" Click="BtnFinishElement_Click"/>

            <Button Content="Отмена" Width="100" Height="42" Margin="12,0" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>