<Window x:Class="UIM.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ПО УИМ - Универсальный измерительный микроскоп" 
        Height="900" Width="1400" 
        WindowState="Maximized">

    <DockPanel>
        <!-- 1. Верхняя панель (Меню + Режим) -->
        <DockPanel DockPanel.Dock="Top" Background="#F0F0F0">
            <Menu DockPanel.Dock="Left">
                <MenuItem Header="Файл">
                    <MenuItem Header="Новый протокол"/>
                    <MenuItem Header="Открыть..."/>
                    <MenuItem Header="Сохранить"/>
                    <Separator/>
                    <MenuItem Header="Выход"/>
                </MenuItem>
                <MenuItem Header="Измерения"/>
                <MenuItem Header="Элементы"/>
                <MenuItem Header="Системы координат"/>
                <MenuItem Header="Отчёты"/>
                <MenuItem Header="Сервис" Visibility="{Binding IsAdminOrMetrologist}">
                    <MenuItem Header="Калибровка" Click="Calibration_Click"/>
                </MenuItem>
            </Menu>

            <!-- Текущий режим и пользователь -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="10">
                <TextBlock Text="Режим:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding CurrentModeDisplay}" 
                           FontWeight="Bold" Foreground="{Binding ModeColor}" 
                           VerticalAlignment="Center" Margin="0,0,20,0"/>

                <TextBlock Text="{Binding CurrentUser.FullName}" VerticalAlignment="Center"/>
                <Button Content="Сменить пользователя" Margin="10,0,0,0" Click="Logout_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- 2. Статус-бар внизу -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding AuditStatus}" Foreground="DarkGreen"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="АО «ЛОМО» • 2026"/>
            </StatusBarItem>
        </StatusBar>

        <!-- 3. Основная рабочая область -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <!-- Дерево элементов -->
                <ColumnDefinition Width="5*"/>
                <!-- Графическая область -->
                <ColumnDefinition Width="280"/>
                <!-- Панель свойств -->
            </Grid.ColumnDefinitions>

            <!-- Дерево элементов (будет реализовано дальше) -->
            <TreeView Grid.Column="0" Margin="5" ItemsSource="{Binding Elements}"/>

            <!-- Графическая область -->
            <Border Grid.Column="1" Margin="5" BorderBrush="Gray" BorderThickness="1">
                <TextBlock Text="Графическая область (MeasuringCanvas)" 
                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                           FontSize="16" Foreground="Gray"/>
                <!-- Здесь позже будет Custom Control -->
            </Border>

            <!-- Панель свойств текущего элемента -->
            <StackPanel Grid.Column="2" Margin="5">
                <TextBlock Text="Свойства элемента" FontWeight="Bold"/>
                <!-- Динамическое содержимое через ContentControl -->
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>