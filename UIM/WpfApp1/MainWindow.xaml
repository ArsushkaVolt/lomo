<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ПО УИМ - Универсальный измерительный микроскоп" 
        Height="960" Width="1680"
        Background="{StaticResource WindowBackground}"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Главное меню -->
            <RowDefinition Height="48"/>
            <!-- Панель инструментов -->
            <RowDefinition Height="*"/>
            <!-- Рабочая область -->
            <RowDefinition Height="28"/>
            <!-- Статус -->
        </Grid.RowDefinitions>

        <!-- Главное меню -->
        <Menu Grid.Row="0" Background="#E0E0E0" FontSize="13">
            <MenuItem Header="Программа">
                <MenuItem Header="Новая"/>
                <MenuItem Header="Открыть"/>
                <MenuItem Header="Сохранить"/>
                <Separator/>
                <MenuItem Header="Выход"/>
            </MenuItem>
            <MenuItem Header="Измерение">
                <MenuItem Header="Одиночное измерение"/>
                <MenuItem Header="Многократное измерение (серия)"/>
                <MenuItem Header="Отмена последней точки"/>
            </MenuItem>
            <MenuItem Header="Просмотр"/>
            <MenuItem Header="Протоколы">
                <MenuItem Header="Протокол измерений        F9"/>
                <MenuItem Header="Протокол статистики"/>
                <MenuItem Header="Распечатка массива"/>
                <MenuItem Header="Ввод атрибутов протокола"/>
                <MenuItem Header="Просмотр протоколов"/>
                <MenuItem Header="Настройка программ протокола"/>
            </MenuItem>
            <MenuItem Header="Настройка">
                <MenuItem Header="Калибровка"/>
            </MenuItem>
            <MenuItem Header="Сервис"/>
            <MenuItem Header="Помощь"/>
            <MenuItem Header="Режим">
                <MenuItem Header="Оператор" Click="Mode_Operator_Click"/>
                <MenuItem Header="Метролог" Click="Mode_Metrologist_Click"/>
                <MenuItem Header="Администратор" Click="Mode_Admin_Click"/>
            </MenuItem>
        </Menu>

        <!-- Панель инструментов -->
        <ToolBar Grid.Row="1" Background="#E8E8E8" ToolBar.OverflowMode="AsNeeded">
            <Button Content="📄" ToolTip="Новый протокол" Width="38" Height="38" FontSize="18" Margin="2"/>
            <Button Content="💾" ToolTip="Сохранить" Width="38" Height="38" FontSize="18" Margin="2"/>
            <Separator/>
            <Button Content="•" ToolTip="Точка" Width="38" Height="38" FontSize="18" Margin="2"/>
            <Button Content="─" ToolTip="Прямая" Width="38" Height="38" FontSize="18" Margin="2"/>
            <Button Content="○" ToolTip="Окружность" Width="38" Height="38" FontSize="18" Margin="2"/>
            <Button Content="⬭" ToolTip="Эллипс" Width="38" Height="38" FontSize="18" Margin="2"/>
            <Separator/>
            <Button Content="📏 Начать измерение" Width="150" Height="42" Background="#007ACC" Foreground="White"
                    Click="BtnStartMeasurement_Click"/>
            <Button Content="📐 СК" Width="50" Height="42" Click="BtnOpenCS_Click"/>
            <CheckBox x:Name="chkMetrologist" Content="Метролог" Margin="20,8" FontSize="14" FontWeight="SemiBold"
                      Checked="chkMetrologist_Checked" Unchecked="chkMetrologist_Unchecked"/>

            
        </ToolBar>

        <!-- Рабочая область -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="8*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Дерево элементов -->
            <DockPanel Grid.Column="0" Background="White" Margin="4">
                <TextBlock Text="Элементы" FontWeight="SemiBold" Margin="8,6"/>
                <TreeView x:Name="treeElements" Margin="4"/>
            </DockPanel>
            <!-- Центральная область: Графика + Панель измерения -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="5*"/>
                    <!-- Графика -->
                    <RowDefinition Height="2*"/>
                    <!-- Панель текущего измерения -->
                </Grid.RowDefinitions>


                <!-- Графическая область -->
                <Border Background="#FAFAFA" BorderBrush="#AAA" BorderThickness="1" Margin="4">
                    <Canvas x:Name="canvas" Background="Transparent"/>
                </Border>

                <!-- Панель активного измерения (совмещённая) -->
                <GroupBox Grid.Row="1" Header="Активное измерение" Margin="4" Foreground="White">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Текущая точка:" FontWeight="SemiBold" />
                            <TextBlock x:Name="txtCurrentCoord" Text="X=0,0000  Y=0,0000" FontSize="14" Margin="4"/>
                            <Button Content="Фиксировать точку" Width="160" Height="36" 
                                    Background="#007ACC" Foreground="White" Click="BtnFixPoint_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="20,0,0,0">
                            <TextBlock Text="Статистика:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtMeasurementInfo" Text="Точек: 0   СКО: —" Margin="4"/>
                            <Button Content="Завершить элемент" Width="160" Height="36" 
                                    Background="#28A745" Foreground="White" Click="BtnFinishElement_Click"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </Grid>

            <!-- Панель свойств -->
            <DockPanel Grid.Column="2" Background="White" Margin="4">
                <TabControl>
                    <TabItem Header="Параметры"/>
                    <TabItem Header="Отклонения"/>
                    <TabItem Header="Допуски"/>
                </TabControl>
            </DockPanel>
        </Grid>

        <!-- Статусная строка -->
        <StatusBar Grid.Row="3" Background="#E0E0E0">
            <StatusBarItem>
                <TextBlock x:Name="statusMode" Text="Режим: Оператор"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="statusText" Text="Готов к измерению"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
   
       