<Window x:Class="WpfApp1.CoordinateSystemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Менеджер систем координат" Height="680" Width="920"
        Background="#F5F5F5">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель: Список СК -->
        <DockPanel Grid.Column="0" Margin="0,0,8,0">
            <TextBlock Text="Системы координат" FontSize="16" FontWeight="SemiBold" 
                       DockPanel.Dock="Top" Margin="0,0,0,8"/>

            <TreeView x:Name="treeCS" Background="White" BorderBrush="#CCC">
                <!-- Заполняется в коде -->
            </TreeView>

            <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" Margin="0,12,0,0">
                <Button Content="Добавить СК" Width="120" Click="BtnAddCS_Click"/>
                <Button Content="Удалить" Width="100" Margin="8,0" Click="BtnDeleteCS_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- Правая панель: Параметры активной СК -->
        <DockPanel Grid.Column="1">
            <GroupBox Header="Параметры системы координат" Margin="8">
                <StackPanel Margin="12">
                    <TextBlock Text="Название СК:" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox x:Name="txtCSName" Text="Рабочая СК 1" Height="28"/>

                    <Separator Margin="0,16"/>

                    <TextBlock Text="Смещение начала (относительно ПСК):" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="X:" Width="30"/>
                        <TextBox x:Name="txtOffsetX" Width="100" Text="0,0000"/>
                        <TextBlock Text="Y:" Width="30" Margin="20,0,0,0"/>
                        <TextBox x:Name="txtOffsetY" Width="100" Text="0,0000"/>
                    </StackPanel>

                    <Separator Margin="0,16"/>

                    <TextBlock Text="Поворот (градусы):" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtRotation" Width="120" Text="0.00" HorizontalAlignment="Left"/>

                    <CheckBox x:Name="chkRelative" Content="Привязать к элементу" Margin="0,16,0,0"/>

                    <Button Content="Применить трансформацию" Margin="0,20,0,0" Height="38" 
                            Background="#007ACC" Foreground="White" Click="BtnApplyTransform_Click"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Информация" DockPanel.Dock="Bottom" Margin="8">
                <TextBlock x:Name="txtInfo" Text="Приборная СК (ПСК) — жёлтая&#10;Активная СК — зелёная" 
                           Margin="12" TextWrapping="Wrap"/>
            </GroupBox>
        </DockPanel>
    </Grid>
</Window>
